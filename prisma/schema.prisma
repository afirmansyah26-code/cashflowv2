generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "linux-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model categories {
  id                    Int                     @id @default(autoincrement())
  user_id               Int?
  name                  String                  @db.VarChar(150)
  created_at            DateTime?               @default(now()) @db.Timestamp(0)
  transactions          transactions[]
  transaction_templates transaction_templates[]
}

model organization_profile {
  id         Int      @id @default(autoincrement())
  app_name   String?  @default("Cashflow App") @db.VarChar(255)
  name       String   @default("Aplikasi Keuangan") @db.VarChar(255)
  subtitle   String?  @db.VarChar(255)
  address    String?  @db.Text
  logo_path  String?  @db.VarChar(255)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(0)
}

model transactions {
  id               Int               @id @default(autoincrement())
  user_id          Int
  category_id      Int?
  transaction_date DateTime          @db.Date
  type             transactions_type
  category         String?           @db.VarChar(150)
  amount           Decimal           @db.Decimal(14, 2)
  note             String?           @db.Text
  admin_notes      String?           @db.Text
  attachment       String?           @db.VarChar(255)
  created_at       DateTime?         @default(now()) @db.Timestamp(0)
  deleted_at       DateTime?         @db.Timestamp(0)
  deleted_by       Int?
  categories       categories?       @relation(fields: [category_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_transactions_category")
  users            users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "transactions_ibfk_1")
  deleted_by_user  users?            @relation("transactions_deleted_byTousers", fields: [deleted_by], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_transactions_deleted_by")

  @@index([user_id], map: "user_id")
  @@index([category_id], map: "fk_transactions_category")
  @@index([deleted_by], map: "fk_transactions_deleted_by")
}

model users {
  id           Int            @id @default(autoincrement())
  username     String         @unique(map: "username") @db.VarChar(100)
  role         users_role?    @default(admin)
  password     String?        @db.VarChar(255)
  created_at      DateTime?      @default(now()) @db.Timestamp(0)
  deleted_at      DateTime?      @db.Timestamp(0)
  session_version Int            @default(0)
  transactions    transactions[]
  deleted_transactions transactions[] @relation("transactions_deleted_byTousers")
  audit_logs      audit_logs[]
  transaction_templates transaction_templates[]
}

model transaction_templates {
  id          Int               @id @default(autoincrement())
  user_id     Int?
  name        String            @db.VarChar(150)
  type        transactions_type
  category_id Int?
  amount      Decimal?          @db.Decimal(14, 2)
  note        String?           @db.Text
  admin_notes String?           @db.Text
  is_global   Boolean           @default(false)
  is_active   Boolean           @default(true)
  created_at  DateTime          @default(now()) @db.Timestamp(0)
  updated_at  DateTime          @default(now()) @updatedAt @db.Timestamp(0)
  deleted_at  DateTime?         @db.Timestamp(0)
  users       users?            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_transaction_templates_user")
  categories  categories?       @relation(fields: [category_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_transaction_templates_category")

  @@index([user_id], map: "idx_transaction_templates_user")
  @@index([category_id], map: "idx_transaction_templates_category")
  @@index([is_global, is_active, deleted_at], map: "idx_transaction_templates_access")
}

model print_headers {
  id               Int      @id @default(autoincrement())
  name             String   @db.VarChar(255)
  institution_name String   @db.VarChar(255)
  subtitle         String?  @db.Text
  address          String?  @db.Text
  phone            String?  @db.VarChar(255)
  bank_info        String?  @db.VarChar(255)
  notary_info      String?  @db.Text
  logo             String?  @db.VarChar(255)
  signer_name      String?  @db.VarChar(255)
  signer_title     String?  @db.VarChar(255)
  signer_city      String?  @db.VarChar(255)
  is_default       Boolean? @default(false)
  created_at       DateTime @default(now()) @db.Timestamp(0)
  updated_at       DateTime @default(now()) @db.Timestamp(0)
}

model audit_logs {
  id          Int      @id @default(autoincrement())
  user_id     Int?
  action      String   @db.VarChar(50)
  entity_type String   @db.VarChar(100)
  entity_id   Int?
  old_value   Json?
  new_value   Json?
  ip_address  String?  @db.VarChar(45)
  user_agent  String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamp(0)
  users       users?   @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_audit_logs_user")

  @@index([user_id], map: "fk_audit_logs_user")
}

enum transactions_type {
  income
  expense
}

enum users_role {
  admin
  staf
}
